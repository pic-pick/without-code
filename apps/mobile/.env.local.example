# ────────────────────────────────────────────
# Supabase (필수)
# EXPO_PUBLIC_ 접두사 = 앱 번들에 포함됨 (클라이언트 공개 키만 사용)
# ────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ────────────────────────────────────────────
# App
# ────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=https://withoutcode.kr

# ────────────────────────────────────────────
# Cloudflare Images
# ────────────────────────────────────────────
EXPO_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net/your-account-hash
