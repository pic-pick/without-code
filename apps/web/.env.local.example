# ────────────────────────────────────────────
# Supabase (필수)
# ────────────────────────────────────────────
# Supabase 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버사이드 전용 — 절대 클라이언트 번들에 포함 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ────────────────────────────────────────────
# App
# ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────
# Upstash Redis (피드 캐시 · Rate Limit · 트렌딩)
# Upstash 대시보드 > Database > REST API 에서 확인
# ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ────────────────────────────────────────────
# Resend (이메일 알림 · 주간 다이제스트)
# resend.com > API Keys 에서 발급
# ────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=no-reply@withoutcode.kr

# ────────────────────────────────────────────
# Cloudflare Images (이미지 CDN)
# Cloudflare 대시보드 > Images > API Tokens 에서 발급
# ────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_IMAGES_API_TOKEN=your-api-token
NEXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net/your-account-hash
